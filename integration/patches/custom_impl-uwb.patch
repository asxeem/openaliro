+int UltraWideBandImpl::_ConfigureRangingSession([[maybe_unused]] SessionIdentifier sessionId,
+						[[maybe_unused]] const CryptoTypes::Ursk &ursk,
+						[[maybe_unused]] ProtocolVersion protocolVersion,
+						[[maybe_unused]] SessionContextHandle sessionContextHandle)
 {
+#ifdef CONFIG_WOZ_ALIRO
+	if (!mAliroCtx) {
+		return -EBUSY;
+	}
+	if (mSession) {
+		LOG_WRN("A ranging session is already active");
