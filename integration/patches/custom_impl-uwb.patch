-int UltraWideBandImpl::_HandleBleMessage([[maybe_unused]] const uint8_t *, [[maybe_unused]] size_t,
-					 [[maybe_unused]] SessionContextHandle)
+int UltraWideBandImpl::_HandleBleMessage(const uint8_t *data, size_t length,
+					 [[maybe_unused]] SessionContextHandle sessionContextData)
 {
+	if (!data || length == 0) {
+		return -EINVAL;
+	}
+#ifdef CONFIG_WOZ_ALIRO
+	if (!mSession) {
+		return -ENOENT;
+	}
+	if (length > kMaxBleMessage) {
+		LOG_ERR("BLE message too long: %zu", length);
+		return -EMSGSIZE;
+	}
+	/* aliro_uwb_session_message_handle does not retain the message, so a stack
+	 * frame (aliro_uwb_message has a flexible data[] member) avoids the heap. */
+	alignas(aliro_uwb_message) uint8_t storage[sizeof(aliro_uwb_message) + kMaxBleMessage];
+	auto *message = reinterpret_cast<aliro_uwb_message *>(storage);
+	message->len = length;
+	memcpy(message->data, data, length);
+	return ConvertErr(aliro_uwb_session_message_handle(mSession, message));
+#else
 	return -ENOSYS;
+#endif // CONFIG_WOZ_ALIRO
 }
 
