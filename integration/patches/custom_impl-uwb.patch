+	int rc = ConvertErr(aliro_uwb_session_set_ursk(session, ursk.data()));
+	if (rc == 0) {
+		rc = ConvertErr(aliro_uwb_session_set_protocol_version(session, protocolVersion));
+	}
+	if (rc != 0) {
+		aliro_uwb_session_destroy(session);
+		return rc;
+	}
+
+	mSession = session;
+	mHandle = sessionContextHandle;
+	LOG_INF("Aliro ranging session configured (sid=0x%08x)", sessionId);
+	return 0;
+#else
 	return -ENOSYS;
+#endif // CONFIG_WOZ_ALIRO
