+void UltraWideBandImpl::ReportRange([[maybe_unused]] SessionContextHandle handle)
+{
+#ifdef CONFIG_WOZ_ALIRO
+	int32_t cm = 0;
+	if (woz_uwb_trusted_range_cm(&cm) && mCallbacks.mRangingData) {
+		if (cm < 0) {
+			cm = 0;
+		}
+		sys_put_be16(static_cast<uint16_t>(cm), mDistanceCm.data());
+		mCallbacks.mRangingData(handle,
+					UwbRangingData{ .mData = mDistanceCm.data(), .mLength = mDistanceCm.size() });
+	}
+#endif // CONFIG_WOZ_ALIRO
+}
+
+#ifdef CONFIG_WOZ_ALIRO
+
+void UltraWideBandImpl::TransmitBleMessage(aliro_uwb_message *message, aliro_uwb_session *uwbSessionCtx, void *userData,
+					   [[maybe_unused]] bool timeout)
+{
+	auto *self = static_cast<UltraWideBandImpl *>(userData);
+	if (message && self && self->mSession == uwbSessionCtx && self->mHandle && self->mCallbacks.mBleMessageTransmit) {
+		self->mCallbacks.mBleMessageTransmit(*self->mHandle, message->data, message->len);
+	}
+	/* Consume the adapter-built message. */
+	aliro_uwb_session_message_free(message);
 }
 
+void UltraWideBandImpl::SessionHandlerCallback(aliro_uwb_session_event *event, void *userData)
+{
+	auto *self = static_cast<UltraWideBandImpl *>(userData);
+	if (!event || !self) {
+		return;
+	}
+
+	if (event->type == ALIRO_UWB_SESSION_EVENT_TYPE_SESSION_STATUS && self->mHandle) {
+		const enum cherry_ccc_session_state st = event->data.status->session_state;
+		if (st == CHERRY_CCC_SESSION_STATE_ACTIVE) {
+			self->mRanging = true;
+			k_work_schedule(&self->mPollWork, K_MSEC(kPollMs));
+		} else if (st == CHERRY_CCC_SESSION_STATE_DEINIT) {
+			self->mRanging = false;
+		}
+		if (self->mCallbacks.mRangingSessionStateChanged) {
+			self->mCallbacks.mRangingSessionStateChanged(*self->mHandle, MapState(st));
+		}
+	} else if (event->type == ALIRO_UWB_SESSION_EVENT_TYPE_SESSION_ERROR) {
+		LOG_INF("Aliro session error: 0x%x", static_cast<unsigned int>(event->data.error->status_err));
+	}
+
+	aliro_uwb_session_event_free(event);
+}
+
+void UltraWideBandImpl::PollWorkHandler(k_work *work)
+{
+	auto *dwork = k_work_delayable_from_work(work);
+	auto *self = CONTAINER_OF(dwork, UltraWideBandImpl, mPollWork);
+	if (self->mRanging && self->mHandle) {
+		self->ReportRange(*self->mHandle);
+		k_work_schedule(&self->mPollWork, K_MSEC(kPollMs));
+	}
+}
+
+#endif // CONFIG_WOZ_ALIRO
+
 } // namespace Aliro::Uwb
