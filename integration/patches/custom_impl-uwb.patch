+int UltraWideBandImpl::_Init(const Callbacks &callbacks)
+{
+	mCallbacks = callbacks;
+
+#ifdef CONFIG_WOZ_ALIRO
+	k_work_init_delayable(&mPollWork, &PollWorkHandler);
+
+	/* No UCI transport to query; our shim's cherry_create is a trivial ctx
+	 * holder and never fires the core callback, so pass nullptr. */
+	mCtx = cherry_create("dw3000-fira", nullptr, this);
+	if (!mCtx) {
+		LOG_ERR("cherry_create failed");
+		return -ENODEV;
+	}
+
+	/* Synthesize the DW3110's Aliro/CCC capabilities (channels 5+9, all slot
+	 * durations, SYNC codes 9..12, default+continuous+no hopping, RAN>=1,
+	 * protocol 1.0, UWB config 0, pulse shape 0). aliro_uwb_adapter_create_reader
+	 * deep-copies these, so the locals need not outlive this call. */
+	static uint16_t proto[] = { 0x0100 };
+	static uint16_t uwbConfigs[] = { 0x0000 };
+	static uint8_t pulseCombos[] = { 0x00 };
+
+	cherry_ccc_capabilities ccc{};
+	ccc.slot_bitmask = 0xFF;
+	ccc.sync_code_index_bitmask = 0x00000F00u; /* codes 9..12. */
+	ccc.hopping_config_bitmask = 0x1A;         /* default(b1)+continuous(b3)+none(b4). */
+	ccc.channel_bitmask = 0x03;                /* ch5 + ch9. */
+	ccc.protocol_versions.len = 1;
+	ccc.protocol_versions.items = proto;
+	ccc.uwb_configs.len = 1;
+	ccc.uwb_configs.items = uwbConfigs;
+	ccc.pulse_shape_combos.len = 1;
+	ccc.pulse_shape_combos.items = pulseCombos;
+	ccc.minimum_ran_multiplier = 1;
+	ccc.qorvo_vendor_feature_1_supported = false;
+
+	cherry_core_event_device_capabilities caps{};
+	caps.status_err = CHERRY_ERR_NONE;
+	caps.ccc_capabilities = &ccc;
+
+	mAliroCtx = aliro_uwb_adapter_create_reader(mCtx, &caps, &mReaderConfig);
+	if (!mAliroCtx) {
+		LOG_ERR("aliro_uwb_adapter_create_reader failed");
+		cherry_destroy_sync(mCtx);
+		mCtx = nullptr;
+		return -EIO;
+	}
+#endif // CONFIG_WOZ_ALIRO
+
+	mInitialized = true;
+	LOG_INF("Woz UWB facade initialized");
+	return 0;
 }
 
