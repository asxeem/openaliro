CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

#enable BT
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y

#disable BT connection reattempt
CONFIG_BT_NIMBLE_ENABLE_CONN_REATTEMPT=n

# Enable L2CAP Connection-Oriented Channels: the Aliro credential-auth transaction
# rides an L2CAP CoC on the reader's SPSM. Default esp-matter NimBLE leaves this at
# 0, so ble_l2cap_create_server() returns BLE_HS_ENOTSUP. Match the bench reader app.
CONFIG_BT_NIMBLE_L2CAP_COC_MAX_NUM=2

# The Aliro reader runs its P-256 credential-auth (ECDH + ECDSA sign/verify + HKDF)
# inside the NimBLE L2CAP callback, i.e. on the nimble_host task. The 4096-byte
# default overflows that stack mid-transaction; the software P-256 path needs more.
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=16384

# Trap stack overflows where they happen, not at the next context switch. The canary
# check (FREERTOS_CHECK_STACKOVERFLOW_CANARY) only runs on a switch, so a task that
# overruns and then returns through the clobbered frame crashes with a corrupted
# backtrace and no task name. The watchpoint panics on the first write into the last
# 32 bytes of any task stack and names the culprit.
CONFIG_FREERTOS_WATCHPOINT_END_OF_STACK=y

#enable lwip ipv6 autoconfig
CONFIG_LWIP_IPV6_AUTOCONFIG=y

# Use a custom partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0xC000

# Disable the CHIP shell: main/app_shell.cpp runs an esp_console REPL on the
# console UART instead, and only one reader of that UART can exist.
CONFIG_ENABLE_CHIP_SHELL=n

# This example only use 2 dynamic endpoints
CONFIG_ESP_MATTER_MAX_DYNAMIC_ENDPOINT_COUNT=2

#enable lwIP route hooks
CONFIG_LWIP_HOOK_IP6_ROUTE_DEFAULT=y
CONFIG_LWIP_HOOK_ND6_GET_GW_DEFAULT=y

# Button
CONFIG_BUTTON_PERIOD_TIME_MS=20
CONFIG_BUTTON_LONG_PRESS_TIME_MS=5000

# disable softap by default
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n

# Enable OTA Requestor
CONFIG_ENABLE_OTA_REQUESTOR=y

# Use compact attribute storage mode
CONFIG_ESP_MATTER_NVS_USE_COMPACT_ATTR_STORAGE=y

# Enable HKDF in mbedtls
CONFIG_MBEDTLS_HKDF_C=y

CONFIG_ENABLE_WIFI_AP=n

# Increase LwIP IPv6 address number to 6 (MAX_FABRIC + 1)
# unique local addresses for fabrics(MAX_FABRIC), a link local address(1)
CONFIG_LWIP_IPV6_NUM_ADDRESSES=6

# ESP32-DevKitC Settings
# Buttons
CONFIG_BSP_BUTTONS_NUM=1
CONFIG_BSP_BUTTON_1_TYPE_GPIO=y
CONFIG_BSP_BUTTON_1_GPIO=0
CONFIG_BSP_BUTTON_1_LEVEL=0
# LEDs
CONFIG_BSP_LEDS_NUM=0

# configurations required for diagnostic logs cluster
# Enable the diagnostic logs transfer over BDX protocol
CONFIG_CHIP_ENABLE_BDX_LOG_TRANSFER=y

CONFIG_ESP32_ENABLE_COREDUMP_TO_FLASH=y
CONFIG_ESP32_COREDUMP_DATA_FORMAT_ELF=y

# disable groupcast cluster until verified
CONFIG_SUPPORT_GROUPCAST_CLUSTER=n

# Advertise Aliro (Apple Home Key) Provisioning + BLE-UWB and register the reader delegate
CONFIG_ENABLE_ALIRO_BLE_UWB=y

# Keep BLE up after commissioning (do NOT deinit/reclaim it). Required for the
# Aliro reader to coexist on Matter's NimBLE host; also, reclaiming BLE makes any
# later nimble_port_init() crash the controller (btdm_controller_init fault).
CONFIG_USE_BLE_ONLY_FOR_COMMISSIONING=n
