# Doxyfile — the "Reference" tree: declarations, macros and types.
#
# Covers only the code this project owns and publishes: the UWB/CCC core and the
# ESP32-S3 reader components. The generated subsystem tree under docs/architecture/
# already covers call graphs and per-file narrative, so this tree exists for what
# that one cannot show: preprocessor constants, enums and struct members.
#
# Built by ./docs.sh into site/api/. Never run doxygen by hand — the site's nav
# link and the link pass both assume that output path.

PROJECT_NAME           = openaliro
PROJECT_BRIEF          = "Aliro reader: UWB/CCC core and ESP32-S3 port"
OUTPUT_DIRECTORY       = site
HTML_OUTPUT            = api
CREATE_SUBDIRS         = NO

INPUT                  = modules/woz_port \
                         modules/woz_uwb \
                         modules/woz_aliro \
                         modules/woz_aliro_ecp \
                         ports/esp32/components/aliro_ble \
                         ports/esp32/components/aliro_crypto \
                         ports/esp32/components/aliro_reader
FILE_PATTERNS          = *.c *.h *.cpp
RECURSIVE              = YES

# The Zephyr compatibility shim is a port scaffold, not project API.
EXCLUDE                = ports/esp32/components/woz_uwb/compat/zephyr
EXCLUDE_PATTERNS       = */build/* */test/*

# Only documented symbols. An undocumented symbol should be fixed at the source,
# not padded out by the generator.
EXTRACT_ALL            = NO
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES

# Protocol constants carry the meaning in this codebase, so macros are the point
# of this tree. Expand only what is predefined here, or the Zephyr and ESP-IDF
# headers drag the whole SDK in.
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
#
# SEARCH_INCLUDES is off, so doxygen never reads a #define out of a header: any
# macro gating real code evaluates to 0 here and takes its whole #if block with
# it, silently. Restate those below. WOZ_CCC_PREPOLL_LISTEN is an unconditional
# `#define ... 1` in ccc_shim.h that guards 547 lines of ccc_shim_rx.c.
PREDEFINED             = __cplusplus= \
                         WOZ_CCC_PREPOLL_LISTEN=1
SEARCH_INCLUDES        = NO

OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
JAVADOC_AUTOBRIEF      = YES
TAB_SIZE               = 8
MARKDOWN_SUPPORT       = YES

GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
SEARCHENGINE           = YES

HTML_EXTRA_STYLESHEET  = docs/_doxygen/doxygen-awesome.css \
                         docs/_doxygen/doxygen-awesome-sidebar-only.css

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = YES
